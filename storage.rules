rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Question-level images (questions/{questionId}/question.jpg etc.)
    // and option images (questions/{questionId}/option-A.jpg etc.)
    match /questions/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Legacy flat path used for new questions whose Firestore ID isn't
    // known at upload time (question-images/{timestamp}-{filename})
    match /question-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}
