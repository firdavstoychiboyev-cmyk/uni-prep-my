rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Reads the caller's role from the users collection.
    // Cached per-request by Firestore so multiple calls don't cost extra reads.
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == "admin";
    }

    function isTeacherOrAdmin() {
      return isSignedIn() && userRole() in ["teacher", "admin"];
    }


    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Any signed-in user can read profiles (needed for class management)
      allow read: if isSignedIn();
      // Users can only write their own profile; admins can write any
      allow write: if isOwner(uid) || isAdmin();

      // ── Sub-collections ───────────────────────────────────────────────────

      match /userProgress/{docId} {
        // Teachers read students' topic progress to derive homework completion
        allow read: if isOwner(uid) || isTeacherOrAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }

      match /testResults/{docId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }

      match /mockResults/{docId} {
        // Completion marks for mock tests; teachers read them for homework tracking
        allow read: if isOwner(uid) || isTeacherOrAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }

      match /badges/{docId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }

      match /ratings/{docId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }

      match /dailyActivity/{docId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }
    }


    // ── Login identifier lookups (username / phone → email) ───────────────────
    // Public `get` is required so the login page can resolve an identifier
    // BEFORE the user is authenticated. `list` stays closed so the collections
    // can't be enumerated. Uniqueness is enforced here: writing to a document
    // owned by another uid is an update, which only the owner may perform.

    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.uid == request.auth.uid) || isAdmin();
    }

    match /phoneNumbers/{phone} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.uid == request.auth.uid) || isAdmin();
    }


    // ── Partner access codes (Registan etc.) ──────────────────────────────────
    // Codes are validated on the signup form before the user is authenticated,
    // so `get` is public. `list` is admin-only (for the admin codes page).
    // The ONLY non-admin write allowed is incrementing usesCount by exactly 1
    // (the atomic use-count bump inside the signup batch), and only while the
    // code is active and under its maxUses limit.

    match /accessCodes/{code} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["usesCount"])
        && request.resource.data.usesCount == resource.data.usesCount + 1
        && resource.data.active == true
        && (!("maxUses" in resource.data)
            || resource.data.maxUses == null
            || resource.data.usesCount < resource.data.maxUses)
      );
    }


    // ── Content collections (admin writes, public read for anonymous browsing) ─

    match /subjects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /textbooks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /topics/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mocks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }


    // ── Classes (teachers and admins manage, students read their own) ─────────

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAdmin();
      allow update, delete: if isTeacherOrAdmin();

      // ── Homework (topic + mock assigned by the class teacher) ────────────
      // Readable by the owning teacher and enrolled students; writable only
      // by the owning teacher (or admin).

      match /homework/{homeworkId} {
        function parentClass() {
          return get(/databases/$(database)/documents/classes/$(classId)).data;
        }
        allow read: if isSignedIn() && (
          parentClass().teacherId == request.auth.uid
          || request.auth.uid in parentClass().students
          || isAdmin()
        );
        allow create, update, delete: if isSignedIn() && (
          parentClass().teacherId == request.auth.uid || isAdmin()
        );
      }
    }

  }
}
